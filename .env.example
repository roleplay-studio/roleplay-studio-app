# =====================================================================
# Roleplay Studio — runtime configuration
# ---------------------------------------------------------------------
# Copy this file to `.env` (same directory) and fill in the values you
# need. Anything left at its default is read by the backend via
# pydantic-settings (see app/infrastructure/config.py).
#
# Boolean parsing is permissive: `1`, `true`, `yes`, `on` → true;
# `0`, `false`, `no`, empty → false. Anything else → true.
# =====================================================================


# ── Required ─────────────────────────────────────────────────────────
# OpenRouter (or any OpenAI-compatible provider) API key.
# Without this the backend refuses to start any LLM calls.
OPENROUTER_API_KEY=sk-or-...n


# ── Provider / LLM ───────────────────────────────────────────────────
# LLM_PROVIDER is only read by the setup wizard as a UI hint.
# The backend itself talks to whatever OPENROUTER_BASE_URL points at.
# LLM_PROVIDER=openrouter

# Base URL of the chat / completions endpoint.
# Override for: OpenRouter (default), LM Studio, Ollama, vLLM,
# DeepSeek, any other OpenAI-compatible host.
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Primary chat model used for roleplay / assistant replies.
# OPENROUTER_BASE_URL defaults to openrouter.ai, so model ids are
# namespaced (e.g. `openai/gpt-oss-20b`). For a local server, just
# use the model id it serves (e.g. `qwen2.5-7b-instruct`).
# CHAT_MODEL=openai/gpt-oss-20b

# Cheap model used for summarization, compression, and the thread
# recap job. Should be fast and cheap — not the same as CHAT_MODEL.
# FAST_MODEL=openai/gpt-4o-mini

# HTTP-Referer header sent with every LLM request (OpenRouter ranking).
# Override in production so you don't leak "this is a Tauri dev box".
# APP_REFERER=http://localhost:1420


# ── Embeddings / RAG ────────────────────────────────────────────────
# Embedding model. Used to build per-bot knowledge bases in Chroma.
# Set to empty string to disable RAG entirely.
# EMBEDDING_MODEL=qwen/qwen3-embedding-8b

# Embeddings endpoint. Falls back to OPENROUTER_BASE_URL when unset.
# Set this when your embedding model lives behind a different host
# (LM Studio, local Ollama with an OpenAI-compatible shim, etc.).
# EMBEDDING_BASE_URL=http://127.0.0.1:1234/v1/

# Auth for the embeddings endpoint. Falls back to OPENROUTER_API_KEY
# when unset. Leave empty for local servers that don't need a key.
# EMBEDDING_API_KEY=

# Cosine-similarity threshold (0..1) below which a knowledge-base hit
# is dropped from the LLM context. Lower = more permissive.
# KNOWLEDGE_RELEVANCE_THRESHOLD=0.3

# Max recent messages kept verbatim in the context window.
# HISTORY_LIMIT=200


# ── Generation defaults ─────────────────────────────────────────────
# LLM sampling temperature. 0.0 = deterministic, 2.0 = chaos.
# DEFAULT_TEMPERATURE=0.7

# Max tokens the model may emit per reply.
# DEFAULT_MAX_TOKENS=4096


# ── Storage ─────────────────────────────────────────────────────────
# SQLite database file. Relative paths resolve against the data dir
# (ROLEPLAY_DATA_DIR in frozen builds, project root in dev).
# DB_PATH=conversations.db

# Chroma persistence directory (one collection per bot lives here).
# CHROMA_PERSIST_DIR=./chroma_db

# Prefix prepended to every per-bot Chroma collection name.
# CHROMA_COLLECTION_PREFIX=kb_bot_

# Where uploaded avatars / attachments land. Relative paths resolve
# against the data dir. Override this to point at a different folder
# (e.g. `demo/uploads` to serve the bundled demo avatars).
# UPLOAD_DIR=uploads


# ── Summarization & context compression ────────────────────────────
# Generate `short_content` for long assistant messages.
# SUMMARIZE_ENABLED=true

# Token budget for each short_content summary.
# SUMMARIZE_MAX_TOKENS=256

# Minimum assistant-message length (chars) before it becomes a
# candidate for summarization.
# SUMMARIZE_MIN_LENGTH=100

# How many recent messages always keep their full content.
# SUMMARIZE_RECENT_LIMIT=10

# Refresh the thread-level recap (thread.summary column) periodically.
# THREAD_SUMMARY_ENABLED=true

# Recap every N assistant messages.
# THREAD_SUMMARY_INTERVAL=10

# Fold old messages into their short_content once the thread is long.
# CONTEXT_COMPRESSION_ENABLED=true

# Start compressing once a thread has more than N messages.
# CONTEXT_COMPRESSION_THRESHOLD=50

# Always keep the most recent N messages at full content even when
# compression is on.
# CONTEXT_COMPRESSION_KEEP_RECENT=20

# Summarize several messages in parallel requests for speed.
# SUMMARIZE_BATCH_ENABLED=true

# Parallel requests per batch. Tune to your provider's rate limit.
# SUMMARIZE_BATCH_SIZE=3


# ── UI ──────────────────────────────────────────────────────────────
# Default UI language (en / ru / de). APP_LANGUAGE is the canonical
# name; LANGUAGE is also accepted for backward compatibility.
# APP_LANGUAGE=en

# Default theme (light / dark / system). Same alias rule as language.
# APP_THEME=system


# ── Debug & logging ─────────────────────────────────────────────────
# Enable dev mode: verbose logs, debug endpoints, payload dumps.
# `DEBUG=true` OR `ENVIRONMENT=development` flips it on.
# DEBUG=false
# ENVIRONMENT=production

# Dump every LLM request/response payload to disk for inspection.
# Also accepts the legacy DEBUG_PAYLOAD_DUMP env name.
# DEBUG_PAYLOAD_DUMP=false

# Where to write payload dumps. Leave unset to disable disk dumps.
# DEBUG_DUMP_DIR=

# Hours before old payload-dump files are swept. 0 disables cleanup.
# DEBUG_DUMP_TTL_HOURS=24

# Stdlib log level (DEBUG / INFO / WARNING / ERROR).
# LOG_LEVEL=INFO

# Log format: `pretty` for human-readable, `json` for ELK/Datadog/Loki.
# LOG_FORMAT=pretty


# ── Advanced (JSON-encoded env vars) ────────────────────────────────
# Per-bot-type preamble overrides. Keys are BotType values: rp,
# assistant, agent. Values replace the built-in preambles. Empty
# string clears the preamble for that type.
# PREAMBLE_OVERRIDES={"rp": "You are a wandering samurai in Edo-era Japan."}

# Field names the LLM stream may use to carry chain-of-thought.
# Order matters: first hit wins. Defaults to OpenRouter-compatible.
# REASONING_FIELD_NAMES=["reasoning_content"]


# ── Optional / rarely needed ────────────────────────────────────────
# Override the data directory (where `.env`, `conversations.db`,
# `chroma_db/`, and `uploads/` live). In normal use this is set
# automatically by backend/run_backend.py — only set it when running
# the API process directly outside the bundled launcher.
# ROLEPLAY_DATA_DIR=~/Library/Application Support/com.nyashkin.roleplay-studio

# Public URL encoded into the QR code by `scripts/print_qr.py`.
# Only used by that helper script, not by the running backend.
# PUBLIC_URL=http://localhost:55245